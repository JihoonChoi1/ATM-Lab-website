generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MemberRole {
  PROFESSOR
  RESEARCHER
  STUDENT
  ALUMNI
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
}

enum PublicationType {
  JOURNAL
  CONFERENCE
  PATENT
}

enum LectureCategory {
  UNDERGRADUATE
  GRADUATE
}

enum UserRole {
  ADMIN
  EDITOR
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Member {
  id              String     @id @default(cuid())
  name            String
  // Not unique: legacy data has the same person registered as both Researcher
  // (current) and Alumni (graduate degree record) with one shared address.
  email           String?
  role            MemberRole
  position        String     // e.g. "Postdoctoral Researcher", "Ph.D. Course", "Alumni"
  interests       String[]   // research interest tags
  imgPath         String?
  year            String?    // enrollment year for students (e.g. "'24"), graduation year for alumni
  degree          String?    // alumni only
  currentPosition String?    // alumni only: current employer/title
  // Professor-only structured data stored as JSON (only one professor row)
  education       Json?      // [{ period: string, title: string, inst: string }]
  workHistory     Json?      // [{ period: string, title: string, inst: string }]
  researchFields  Json?      // [{ group: string, items: [{ label: string, subs: string[] }] }]
  lectureSubjects Json?      // [{ title: string, code: string }]
  published       Boolean    @default(true)
  order           Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  title       String
  institution String
  period      String
  scale       String?
  status      ProjectStatus
  published   Boolean       @default(true)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Publication {
  id            String          @id @default(cuid())
  type          PublicationType
  year          String
  title         String
  authors       String?
  // Journal
  journal       String?
  doi           String?
  // Conference
  conference    String?
  // Patent
  inventors     String?
  applicationNo String?
  country       String?
  registeredAt  String?
  imgPath       String?
  published     Boolean         @default(true)
  order         Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Lecture {
  id         String          @id @default(cuid())
  num        String
  category   LectureCategory
  title      String
  paragraphs String[]
  published  Boolean         @default(true)
  order      Int             @default(0)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model News {
  id        String   @id @default(cuid())
  date      DateTime
  title     String
  content   String?  @db.Text
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryItem {
  id        String   @id @default(cuid())
  date      DateTime
  title     String
  imgPath   String?
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResearchTopic {
  id          String               @id @default(cuid())
  num         String               @unique // "01", "02", …
  title       String
  lead        String
  keywords    String[]
  bg          String               @default("white") // "white" | "bg"
  subsections ResearchSubsection[]
  published   Boolean              @default(true)
  order       Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model ResearchSubsection {
  id        String           @id @default(cuid())
  topicId   String
  topic     ResearchTopic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  num       String           // "01.01", "01.02", …
  title     String
  body      String           @db.Text
  keywords  String[]
  figures   ResearchFigure[]
  published Boolean          @default(true)
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ResearchFigure {
  id           String             @id @default(cuid())
  subsectionId String
  subsection   ResearchSubsection @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  imgPath      String?
  caption      String
  width        Int
  height       Int
  // Public gallery emphasis: when true, a multi-figure subsection renders this
  // figure across the full row (and at a taller height cap) instead of one slot.
  wide         Boolean            @default(false)
  order        Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

// Singleton — exactly one row. Hero copy + Years stat for the Research page.
// Topics / Subtopics counts are derived from DB at query time, not stored here.
model ResearchPageMeta {
  id            String   @id @default(cuid())
  heroHeadline  String   // two-line headline, newline-separated
  heroParagraph String   @db.Text
  yearsValue    String   // e.g. "10+"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Singletons — exactly one row each. Hero copy (multi-line headline + intro
// paragraph) for the remaining public pages. Same shape as ResearchPageMeta
// minus the page-specific stat; the stat numbers/lists stay DB-computed.
model MembersPageMeta {
  id            String   @id @default(cuid())
  heroHeadline  String   // newline-separated; public hero splits on "\n"
  heroParagraph String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProjectsPageMeta {
  id            String   @id @default(cuid())
  heroHeadline  String
  heroParagraph String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PublicationsPageMeta {
  id            String   @id @default(cuid())
  heroHeadline  String
  heroParagraph String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LecturesPageMeta {
  id            String   @id @default(cuid())
  heroHeadline  String
  heroParagraph String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BoardPageMeta {
  id            String   @id @default(cuid())
  heroHeadline  String
  heroParagraph String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  totpSecret   String?
  role         UserRole   @default(ADMIN)
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // "CREATE" | "UPDATE" | "DELETE"
  entity    String   // model name
  entityId  String?
  data      Json?    // before/after snapshot
  createdAt DateTime @default(now())
}

model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

// unique-visitor analytics. One row per visitor per day — never the
// raw IP/UA. visitorId = sha256(ip + ua + "YYYYMMDD"(KST) + VISITOR_SALT), so the
// same person on the same day collapses to one hash; a new day yields a new hash.
// @unique makes "one row per visitor per day" an atomic DB guarantee (writes use
// createMany skipDuplicates) and already indexes visitorId, so no separate index.
model PageView {
  id        String   @id @default(cuid())
  visitorId String   @unique
  // timestamptz so the stored instant is unambiguous; the admin buckets/filters
  // by KST day (AT TIME ZONE 'Asia/Seoul') regardless of the server's timezone.
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([createdAt])
}
